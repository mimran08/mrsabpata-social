{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["index.ts", "roles/**/*", "company/**/*.ts", "platforms/**/*", "commands/**/*", "scheduler/**/*", "utils/**/*"],
  "exclude": ["node_modules", "app", "dist"]
}
